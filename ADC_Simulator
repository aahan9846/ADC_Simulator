<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signal Processor - Professional Lab Simulator</title>
    <style>
        :root {
            --bg-dark: #0a0b10;
            --panel-bg: #14161f;
            --border: #2a2d3e;
            --text-main: #e0e6ed;
            --text-dim: #717b91;
            --analog-blue: #00d2ff;
            --sample-yellow: #ffcc00;
            --quant-red: #ff4d4d;
            --dac-green: #00ff88;
            --bit-cyan: #00ffff;
        }

        html, body {
            margin: 0; padding: 0;
            height: 100vh; width: 100vw;
            overflow: hidden;
            background-color: var(--bg-dark);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--text-main);
        }

        body { display: flex; flex-direction: column; }

        header {
            height: 50px;
            background-color: var(--panel-bg);
            padding: 0 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .brand h1 { font-size: 0.9rem; letter-spacing: 2px; color: var(--analog-blue); margin: 0; }
        .brand p { font-size: 0.55rem; color: var(--text-dim); text-transform: uppercase; margin: 0; }

        .transport { display: flex; gap: 10px; }
        button {
            padding: 6px 14px;
            border: none; border-radius: 4px;
            cursor: pointer; font-weight: 700; font-size: 0.65rem;
            text-transform: uppercase; transition: 0.2s;
        }
        #playBtn { background-color: #238636; color: white; }
        #pauseBtn { background-color: #d29922; color: white; }
        #resetBtn { background-color: #484f58; color: white; }
        button:hover { filter: brightness(1.2); }

        main { display: flex; flex: 1; min-height: 0; }

        #controls {
            width: 260px;
            background-color: var(--panel-bg);
            padding: 20px;
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column; gap: 20px;
            flex-shrink: 0;
        }

        .control-group h3 { 
            font-size: 0.7rem; color: var(--text-dim); margin-bottom: 12px; 
            letter-spacing: 1px; border-left: 2px solid var(--analog-blue); padding-left: 8px; 
        }

        .control-group label {
            display: flex; justify-content: space-between;
            font-size: 0.65rem; color: var(--text-dim); margin-bottom: 6px; font-weight: bold;
        }
        .control-group label span { color: var(--analog-blue); font-family: monospace; font-size: 0.8rem; }

        input[type=range] {
            width: 100%; height: 4px; background: #2a2d3e;
            appearance: none; outline: none; margin-bottom: 15px;
        }
        input[type=range]::-webkit-slider-thumb {
            appearance: none; width: 14px; height: 14px;
            background: var(--analog-blue); border-radius: 50%; cursor: pointer;
        }
        
        #in-zoom::-webkit-slider-thumb { background: #fff; }

        #viewport {
            flex: 1; display: grid;
            grid-template-rows: repeat(5, 1fr); 
            gap: 1px; background-color: var(--border); min-height: 0;
        }

        .screen { position: relative; background-color: var(--bg-dark); overflow: hidden; }

        .screen-label {
            position: absolute; top: 6px; left: 12px;
            font-size: 0.55rem; font-weight: 800; text-transform: uppercase;
            background: rgba(10, 11, 16, 0.9); padding: 3px 7px;
            border-radius: 3px; z-index: 5; border: 1px solid var(--border);
        }

        canvas { width: 100%; height: 100%; display: block; }

        .c1 { color: var(--analog-blue); }
        .c2 { color: var(--sample-yellow); }
        .c3 { color: var(--quant-red); }
        .c4 { color: var(--dac-green); }
        .c5 { color: var(--bit-cyan); }

    </style>
</head>
<body>

<header>
    <div class="brand">
        <h1>SIGNAL PROCESSOR</h1>
        <p>Advanced ADC/DAC Analysis Laboratory</p>
    </div>
    <div class="transport">
        <button id="playBtn">PLAY</button>
        <button id="pauseBtn">PAUSE</button>
        <button id="resetBtn">RESET</button>
    </div>
</header>

<main>
    <aside id="controls">
        <div class="control-group">
            <h3>ANALOG INPUT</h3>
            <label>AMPLITUDE <span id="lbl-amp">2.5 V</span></label>
            <input type="range" id="in-amp" min="0.1" max="4.8" step="0.1" value="2.5">
            
            <label>FREQUENCY <span id="lbl-freq">1.0 HZ</span></label>
            <input type="range" id="in-freq" min="0.1" max="5.0" step="0.1" value="1.0">
        </div>

        <div class="control-group">
            <h3>OSCILLOSCOPE VIEW</h3>
            <label>HORIZONTAL ZOOM <span id="lbl-zoom">1.0x</span></label>
            <input type="range" id="in-zoom" min="0.5" max="5.0" step="0.1" value="1.0">
        </div>

        <div style="margin-top: auto; font-size: 0.6rem; color: var(--text-dim); line-height: 1.5; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 5px;">
            <strong>Pro Tip:</strong> Zoom in (3.0x+) to clearly see the "steps" of the 4-bit quantization and individual logic bits.
        </div>
    </aside>

    <div id="viewport">
        <div class="screen"><div class="screen-label c1">1. Analog Source</div><canvas id="can-analog"></canvas></div>
        <div class="screen"><div class="screen-label c2">2. Sample & Hold</div><canvas id="can-sample"></canvas></div>
        <div class="screen"><div class="screen-label c3">3. Quantized Signal</div><canvas id="can-quant"></canvas></div>
        <div class="screen"><div class="screen-label c5">4. Digital Bitstream (4-bit Serial)</div><canvas id="can-bits"></canvas></div>
        <div class="screen"><div class="screen-label c4">5. DAC Output</div><canvas id="can-dac"></canvas></div>
    </div>
</main>

<script>
    const CONFIG = {
        bufferSize: 1500, // Large buffer to support zooming out
        sampleRate: 40,   // Samples per second
        vRange: 10        // -5V to +5V
    };

    let state = {
        running: true,
        time: 0,
        lastSampleTime: 0,
        amp: 2.5,
        freq: 1.0,
        zoom: 1.0,
        // Buffers
        history: [] // Array of {t, v, q, bits[]}
    };

    const canvasIds = ['analog', 'sample', 'quant', 'bits', 'dac'];
    const canvases = {};
    const ctxs = {};

    function init() {
        canvasIds.forEach(id => {
            canvases[id] = document.getElementById(`can-${id}`);
            ctxs[id] = canvases[id].getContext('2d');
        });

        window.addEventListener('resize', resize);
        resize();

        // UI Handlers
        document.getElementById('in-amp').oninput = e => {
            state.amp = parseFloat(e.target.value);
            document.getElementById('lbl-amp').innerText = state.amp.toFixed(1) + " V";
        };
        document.getElementById('in-freq').oninput = e => {
            state.freq = parseFloat(e.target.value);
            document.getElementById('lbl-freq').innerText = state.freq.toFixed(1) + " HZ";
        };
        document.getElementById('in-zoom').oninput = e => {
            state.zoom = parseFloat(e.target.value);
            document.getElementById('lbl-zoom').innerText = state.zoom.toFixed(1) + "x";
        };

        document.getElementById('playBtn').onclick = () => state.running = true;
        document.getElementById('pauseBtn').onclick = () => state.running = false;
        document.getElementById('resetBtn').onclick = () => {
            state.time = 0;
            state.lastSampleTime = 0;
            state.history = [];
        };

        requestAnimationFrame(loop);
    }

    function resize() {
        canvasIds.forEach(id => {
            canvases[id].width = canvases[id].parentElement.clientWidth;
            canvases[id].height = canvases[id].parentElement.clientHeight;
        });
    }

    // --- Math ---
    function getAnalogVal(t) {
        return state.amp * Math.sin(2 * Math.PI * state.freq * t);
    }

    function getQuantized(v) {
        const levels = 16; // 4-bit
        const step = 10 / (levels - 1);
        const idx = Math.round((v + 5) / step);
        const qV = (idx * step) - 5;
        const bits = idx.toString(2).padStart(4, '0').split('').map(Number);
        return { voltage: qV, bits: bits };
    }

    // --- Core Loop ---
    function loop() {
        if (state.running) {
            state.time += 1/60;

            const interval = 1 / CONFIG.sampleRate;
            if (state.time - state.lastSampleTime >= interval) {
                const v = getAnalogVal(state.time);
                const q = getQuantized(v);
                
                state.history.push({
                    t: state.time,
                    v: v,
                    q: q.voltage,
                    bits: q.bits
                });

                if (state.history.length > CONFIG.bufferSize) state.history.shift();
                state.lastSampleTime = state.time;
            }
        }
        render();
        requestAnimationFrame(loop);
    }

    // --- Rendering ---
    function render() {
        const w = canvases.analog.width;
        const h = canvases.analog.height;

        // Shared drawing params
        // Pixels per second: base 150px, adjusted by zoom
        const pxPerSec = 150 * state.zoom;

        canvasIds.forEach(id => {
            const ctx = ctxs[id];
            ctx.clearRect(0,0,w,h);
            drawGrid(ctx, w, h);

            if (id === 'analog') {
                renderAnalog(ctx, w, h, pxPerSec);
            } else if (id === 'bits') {
                renderBitstream(ctx, w, h, pxPerSec);
            } else {
                const colors = { sample: '#ffcc00', quant: '#ff4d4d', dac: '#00ff88' };
                const mode = id === 'sample' ? 'v' : 'q';
                renderHistoryWave(ctx, w, h, pxPerSec, colors[id], mode, id === 'sample');
            }
        });
    }

    function drawGrid(ctx, w, h) {
        ctx.strokeStyle = 'rgba(255,255,255,0.03)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        for(let x=w; x>0; x -= 50) { ctx.moveTo(x, 0); ctx.lineTo(x, h); }
        for(let y=0; y<h; y += h/6) { ctx.moveTo(0, y); ctx.lineTo(w, y); }
        ctx.stroke();
        ctx.strokeStyle = 'rgba(255,255,255,0.1)';
        ctx.beginPath(); ctx.moveTo(0, h/2); ctx.lineTo(w, h/2); ctx.stroke();
    }

    function mapY(v, h) { return h - (((v + 5) / 10) * h); }

    function renderAnalog(ctx, w, h, pxPerSec) {
        ctx.strokeStyle = '#00d2ff'; ctx.lineWidth = 2;
        ctx.beginPath();
        for (let x = 0; x < w; x++) {
            const tOffset = (x - w) / pxPerSec;
            const y = mapY(getAnalogVal(state.time + tOffset), h);
            if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.stroke();
    }

    function renderHistoryWave(ctx, w, h, pxPerSec, color, key, drawDots) {
        if (state.history.length < 2) return;
        ctx.strokeStyle = color; ctx.lineWidth = 2;
        ctx.beginPath();

        let lastX = -1;
        for (let i = 0; i < state.history.length; i++) {
            const item = state.history[i];
            const x = w + (item.t - state.time) * pxPerSec;
            
            if (x < -20) continue; // Skip off-screen
            if (x > w + 20) break;

            const y = mapY(item[key], h);
            if (lastX === -1) {
                ctx.moveTo(x, y);
            } else {
                // Staircase: Hold previous Y until new X
                const prevY = mapY(state.history[i-1][key], h);
                ctx.lineTo(x, prevY);
                ctx.lineTo(x, y);
            }
            lastX = x;
        }
        ctx.stroke();

        if (drawDots) {
            ctx.fillStyle = color;
            state.history.forEach(item => {
                const x = w + (item.t - state.time) * pxPerSec;
                if (x > 0 && x < w) {
                    ctx.beginPath(); ctx.arc(x, mapY(item[key], h), 2, 0, Math.PI*2); ctx.fill();
                }
            });
        }
    }

    function renderBitstream(ctx, w, h, pxPerSec) {
        if (state.history.length < 1) return;
        ctx.strokeStyle = '#00ffff'; ctx.lineWidth = 1.5;
        ctx.beginPath();

        const bitWidth = (1 / CONFIG.sampleRate) * pxPerSec / 4; // Width of 1 bit pulse

        for (let i = 0; i < state.history.length; i++) {
            const item = state.history[i];
            let startX = w + (item.t - state.time) * pxPerSec;
            
            if (startX > w || startX + (bitWidth*4) < 0) continue;

            item.bits.forEach((bit, bitIdx) => {
                const x = startX + (bitIdx * bitWidth);
                const y = mapY(bit === 1 ? 2.5 : -2.5, h);
                
                if (i === 0 && bitIdx === 0) {
                    ctx.moveTo(x, y);
                } else {
                    // Logic Staircase
                    const prevBit = bitIdx === 0 ? state.history[i-1]?.bits[3] : item.bits[bitIdx-1];
                    const prevY = mapY(prevBit === 1 ? 2.5 : -2.5, h);
                    ctx.lineTo(x, prevY);
                    ctx.lineTo(x, y);
                }
                ctx.lineTo(x + bitWidth, y);
            });
        }
        ctx.stroke();
    }

    init();
</script>
</body>
</html>
